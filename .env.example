# Telegram API Credentials (можно получить на my.telegram.org)
TG_API_ID=12345678
TG_API_HASH=your_telegram_api_hash_here
TG_SESSION_PATH=session_name

# Интеграция с n8n (адреса вебхуков из твоих воркфлоу)
PARSER_CONFIG_URL=https://your-n8n-instance.com/webhook/get-config-parser
PARSER_LEADS_URL=https://your-n8n-instance.com/webhook/main-parser-input

# ID чата для отправки уведомления о запуске парсера (опционально)
TG_CHAT_ID=-100123456789

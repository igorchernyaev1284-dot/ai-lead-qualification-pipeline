      "parameters": {
        "jsCode": "// Берем данные напрямую со входа, не привязываясь к названию предыдущего узла\nconst incomingData = $input.first().json;\nlet rawText = \"\";\n\nif (incomingData.output && Array.isArray(incomingData.output)) {\n    rawText = incomingData.output[0]?.content[0]?.text || \"\";\n} else if (incomingData.output && typeof incomingData.output === 'string') {\n    rawText = incomingData.output;\n} else if (incomingData.text) {\n    rawText = incomingData.text;\n} else if (incomingData.message && incomingData.message.content) {\n    rawText = incomingData.message.content;\n} else {\n    rawText = JSON.stringify(incomingData);\n}\n\ntry {\n    let cleanText = rawText.replace(/\\n/g, ' ');\n    return { text: cleanText };\n} catch (e) {\n    return { text: rawText };\n}"
